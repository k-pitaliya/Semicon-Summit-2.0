# Frontend Environment Variables

# API URL Configuration
# Local development: http://localhost:5000/api
# Production (Render): https://semicon-summit-2-0semicon-summit-api.onrender.com/api
VITE_API_URL=https://semicon-summit-2-0semicon-summit-api.onrender.com/api

# Registration state — set to 'true' to enable the registration form
# Ensure the backend REGISTRATION_OPEN env var is also set to 'true'
VITE_REGISTRATION_OPEN=false
